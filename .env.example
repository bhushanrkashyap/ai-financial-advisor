# Application
APP_NAME=ai-financial-advisor
APP_ENV=development
DEBUG=false

# API
API_HOST=0.0.0.0
API_PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/financial_advisor

# CORS (comma-separated origins for production)
CORS_ORIGINS=http://localhost:5173

# Secrets (replace in deployment)
SECRET_KEY=change-me-in-production

# Optional: external services (placeholders)
# OPENAI_API_KEY=
# ML_SERVICE_URL=http://localhost:9000
# JAVA_ENGINE_URL=http://localhost:8080
